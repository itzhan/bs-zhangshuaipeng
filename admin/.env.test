# backend api base url — Docker 部署时走 Nginx 反代
VITE_SERVICE_BASE_URL=/api

# other backend api base url (json5)
VITE_OTHER_SERVICE_BASE_URL=

VITE_BASE_URL=/admin/

VITE_APP_TITLE=流浪宠物救助管理系统

VITE_APP_DESC=基于Spring Boot的流浪宠物救助系统后台管理

VITE_ICON_PREFIX=icon

VITE_ICON_LOCAL_PREFIX=icon-local

# auth route mode: static | dynamic
VITE_AUTH_ROUTE_MODE=static

# static auth route home
VITE_ROUTE_HOME=home

# default menu icon
VITE_MENU_ICON=mdi:menu

# whether to enable http proxy when is dev mode
VITE_HTTP_PROXY=Y

# vue-router mode
VITE_ROUTER_HISTORY_MODE=history

# success code — match Spring Boot backend Result.code = 200
VITE_SERVICE_SUCCESS_CODE=200

# logout codes
VITE_SERVICE_LOGOUT_CODES=401

# modal logout codes
VITE_SERVICE_MODAL_LOGOUT_CODES=403

# token expired codes
VITE_SERVICE_EXPIRED_TOKEN_CODES=

# super role for static routes
VITE_STATIC_SUPER_ROLE=ROLE_ADMIN

# sourcemap
VITE_SOURCE_MAP=N

VITE_STORAGE_PREFIX=PET_ADMIN_

VITE_AUTOMATICALLY_DETECT_UPDATE=N

VITE_PROXY_LOG=Y

VITE_DEVTOOLS_LAUNCH_EDITOR=code
